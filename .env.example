# Copy this file to `.env` and adjust the values.
# `.env` itself must NOT be committed (see .gitignore).

# --- Database ---
# DB_HOST matches the mysql service name in docker-compose.
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=changeme
DB_NAME=wfh_attendance

# --- JWT ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=1d

# --- Microservice transport (TCP) ---
# Hosts match the service names in docker-compose so containers can
# reach each other over the internal Docker network.
EMPLOYEE_SERVICE_HOST=employee-service
EMPLOYEE_SERVICE_PORT=3001
ATTENDANCE_SERVICE_HOST=attendance-service
ATTENDANCE_SERVICE_PORT=3002

# --- Gateway ---
GATEWAY_PORT=3000

# --- File upload ---
UPLOAD_DIR=./uploads
